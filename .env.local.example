# Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://shammasinvestments.com
NEXT_PUBLIC_SITE_NAME=Shammas Investments

# ============================================
# FREE INTEGRATIONS (See SETUP_INTEGRATIONS.md)
# ============================================

# Web3Forms (Contact Form) - FREE unlimited submissions
# Get your key at: https://web3forms.com/
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your_web3forms_access_key_here

# Mailchimp (Newsletter) - FREE up to 500 contacts
# Get your embedded form URL from: Audience → Signup forms → Embedded forms
# Example: https://shammasinvestments.us12.list-manage.com/subscribe/post?u=xxx&id=xxx
NEXT_PUBLIC_MAILCHIMP_URL=your_mailchimp_embedded_form_url_here

# Calendly (Scheduling) - FREE unlimited 1-on-1 meetings
# Get your link at: https://calendly.com/
# Example: https://calendly.com/shammas-investments/consultation
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-username/consultation

# ============================================
# OPTIONAL CONFIGURATIONS
# ============================================

# Contact Information (optional - update in code if not using env vars)
# NEXT_PUBLIC_CONTACT_EMAIL=info@shammasinvestments.com
# NEXT_PUBLIC_SUPPORT_EMAIL=support@shammasinvestments.com

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Social Media (optional - update in code if not using env vars)
# NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/company/shammas-investments
# NEXT_PUBLIC_TWITTER_URL=https://twitter.com/shammasinvest
# NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/shammasinvestments
# NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/shammasinvestments
# NEXT_PUBLIC_GITHUB_URL=https://github.com/shammas-investments
