# Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://shammasdevelopment.com
NEXT_PUBLIC_SITE_NAME=Shammas Development

# ============================================
# FREE INTEGRATIONS (See SETUP_INTEGRATIONS.md)
# ============================================

# Web3Forms (Contact Form) - FREE unlimited submissions
# Get your key at: https://web3forms.com/
# IMPORTANT: Server-side only (no NEXT_PUBLIC_ prefix for security)
WEB3FORMS_ACCESS_KEY=your_web3forms_access_key_here

# Brevo (Newsletter) - FREE up to 300 emails/day
# Get your API key from: https://app.brevo.com/settings/keys/api
# Get your List ID from: Contacts → Lists → click on list → ID shown in URL
BREVO_API_KEY=your_brevo_api_key_here
BREVO_LIST_ID=2
# Sender email MUST be verified in Brevo (Settings → Senders & IP)
BREVO_SENDER_EMAIL=info@shammasdevelopment.com
BREVO_SENDER_NAME=Shammas Development

# Calendly (Scheduling) - FREE unlimited 1-on-1 meetings
# Get your link at: https://calendly.com/
# Example: https://calendly.com/shammas-development/consultation
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-username/consultation

# ============================================
# OPTIONAL CONFIGURATIONS
# ============================================

# Contact Information (optional - update in code if not using env vars)
# NEXT_PUBLIC_CONTACT_EMAIL=info@shammasdevelopment.com
# NEXT_PUBLIC_SUPPORT_EMAIL=support@shammasdevelopment.com

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Social Media (optional - update in code if not using env vars)
# NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/company/shammas-development
# NEXT_PUBLIC_TWITTER_URL=https://twitter.com/shammasdev
# NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/shammasdevelopment
# NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/shammasdevelopment
# NEXT_PUBLIC_GITHUB_URL=https://github.com/shammas-development
